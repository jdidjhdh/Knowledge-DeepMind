# ============================================
# 知识库系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================

# ============================================
# LLM 配置 (DeepSeek)
# ============================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 数据库配置 (PostgreSQL)
# 推荐使用 Neon 或 Supabase 的 PostgreSQL 服务
# 方式一: 完整连接字符串
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/knowledge_db

# 方式二: 按字段配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=knowledge_db

# ============================================
# Neo4j 图数据库配置
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ============================================
# Redis 配置 (Upstash / 本地)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# MinIO / S3 / Cloudflare R2 对象存储配置
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-base

# ============================================
# 认证配置
# ============================================
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# 语音识别配置 (可选)
# ============================================
SPEECH_API_KEY=your-speech-api-key
SPEECH_BASE_URL=https://api.openai.com/v1

# ============================================
# 视觉识别配置 (可选)
# ============================================
VISION_API_KEY=your-vision-api-key
VISION_BASE_URL=https://api.openai.com/v1

# ============================================
# Embedding 向量化配置
# ============================================
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIM=1536

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50